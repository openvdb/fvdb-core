@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# fvdb's public headers use Torch types; Torch must be found before using fvdb.
# In most cases the consuming project will have already called find_package(Torch)
# or used get_torch.cmake before find_package(fvdb), making this a no-op.
find_dependency(Torch)

include("${CMAKE_CURRENT_LIST_DIR}/fvdbTargets.cmake")

check_required_components(fvdb)
